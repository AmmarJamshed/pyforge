# Copy to .env and fill in your values

# AI backend: groq | gemini | openai | openrouter | ollama
AI_PROVIDER=gemini
AI_MAX_INPUT_CHARS=8000

# Google Gemini (recommended for cloud — free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (optional — strict free-tier limits)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-70b-versatile

# OpenAI / OpenRouter / Ollama (OpenAI-compatible)
OPENAI_API_KEY=your_openai_or_openrouter_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

ARTIFACTS_DIR=/app/artifacts
ARTIFACT_TTL_SECONDS=3600
BUILD_TIMEOUT_SECONDS=1800

DESKTOP_IMAGE=pyforge-builder-desktop:latest
ANDROID_IMAGE=pyforge-builder-android:latest

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
