# Copy to .env and fill in your values
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-70b-versatile

ARTIFACTS_DIR=/app/artifacts
ARTIFACT_TTL_SECONDS=3600
BUILD_TIMEOUT_SECONDS=1800

DESKTOP_IMAGE=pyforge-builder-desktop:latest
ANDROID_IMAGE=pyforge-builder-android:latest

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
